{
  "name": "avatar-registry",
  "packageManager": "yarn@4.11.0",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 0.0.0.0",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
    "topng": "node -r @hydrooj/register topng.ts",
    "import": "node -r @hydrooj/register import.ts",
    "deploy": "node -r @hydrooj/register deploy.ts"
  },
  "dependencies": {
    "@hydrooj/register": "^1.0.4",
    "lucide-react": "^1.22.0",
    "p-queue": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/react": "^6.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.4",
    "typescript": "^5.9.3"
  }
}
